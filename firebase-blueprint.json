{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A menu item offered by Bembe Cafe.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Coffee & Drinks", "Food & Brunch", "Cakes & Pastries", "Specials"] },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "available": { "type": "boolean" },
        "allergens": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "order": { "type": "number" }
      },
      "required": ["name", "category", "price", "imageUrl", "available"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for food or drinks.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "qty": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "total": { "type": "number" },
        "type": { "type": "string", "enum": ["collect", "delivery"] },
        "pickupTime": { "type": "string" },
        "deliveryAddress": {
          "type": "object",
          "properties": {
            "postcode": { "type": "string" },
            "street": { "type": "string" }
          }
        },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "preparing", "ready", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "items", "total", "type", "status", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A table reservation at the cafe.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "guests": { "type": "number" },
        "requests": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "email", "date", "time", "guests", "status", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Menu products"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Table bookings"
    }
  }
}
